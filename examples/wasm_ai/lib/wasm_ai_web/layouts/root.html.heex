<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title>WASM AI Demo - Exclosured</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 2rem; background: #1a1a2e; color: #eee; }
      h1 { margin-bottom: 1rem; color: #e94560; }
      p.desc { color: #aaa; margin-bottom: 2rem; }
      textarea { width: 100%; height: 120px; padding: 0.75rem; border-radius: 8px; border: 1px solid #333; background: #16213e; color: #eee; font-size: 1rem; resize: vertical; }
      button { margin-top: 1rem; padding: 0.75rem 2rem; border: none; border-radius: 8px; background: #e94560; color: white; font-size: 1rem; cursor: pointer; }
      button:hover { background: #c73e54; }
      button:disabled { opacity: 0.5; cursor: not-allowed; }
      .result { margin-top: 2rem; padding: 1rem; border-radius: 8px; background: #16213e; border: 1px solid #333; }
      .result h3 { color: #e94560; margin-bottom: 0.5rem; }
      .result pre { white-space: pre-wrap; word-break: break-all; color: #7ec8e3; }
      .progress { margin-top: 1rem; height: 4px; background: #333; border-radius: 2px; overflow: hidden; }
      .progress-bar { height: 100%; background: #e94560; transition: width 0.3s; }
      .status { color: #aaa; font-size: 0.9rem; margin-top: 0.5rem; }
    </style>
  </head>
  <body>
    <%= @inner_content %>
    <script defer phx-track-static src={"/assets/app.js"}></script>
  </body>
</html>
