<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title>Markdown Editor | LiveSvelte + Exclosured WASM</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css" />
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.js"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/contrib/auto-render.min.js"></script>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background: #0d1117;
        color: #c9d1d9;
        min-height: 100vh;
      }

      header {
        padding: 1rem 2rem;
        border-bottom: 1px solid #21262d;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      header h1 {
        font-size: 1.25rem;
        font-weight: 600;
        color: #58a6ff;
      }

      header .badge {
        font-size: 0.7rem;
        padding: 0.15rem 0.5rem;
        border-radius: 999px;
        background: #1f6feb33;
        color: #58a6ff;
        border: 1px solid #1f6feb55;
      }

      main {
        height: calc(100vh - 57px);
      }

      /* Preview pane styling for rendered HTML */
      .preview-content h1 { font-size: 1.8rem; margin: 1rem 0 0.5rem; color: #f0f6fc; border-bottom: 1px solid #21262d; padding-bottom: 0.3rem; }
      .preview-content h2 { font-size: 1.4rem; margin: 0.8rem 0 0.4rem; color: #f0f6fc; border-bottom: 1px solid #21262d; padding-bottom: 0.3rem; }
      .preview-content h3 { font-size: 1.15rem; margin: 0.7rem 0 0.3rem; color: #f0f6fc; }
      .preview-content p { margin: 0.5rem 0; line-height: 1.6; }
      .preview-content code { background: #161b22; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.9em; color: #79c0ff; }
      .preview-content pre { background: #161b22; padding: 1rem; border-radius: 6px; overflow-x: auto; margin: 0.5rem 0; }
      .preview-content pre code { background: none; padding: 0; }
      .preview-content blockquote { border-left: 3px solid #3b82f6; padding-left: 1rem; color: #8b949e; margin: 0.5rem 0; }
      .preview-content ul, .preview-content ol { padding-left: 1.5rem; margin: 0.5rem 0; }
      .preview-content li { margin: 0.25rem 0; }
      .preview-content a { color: #58a6ff; text-decoration: none; }
      .preview-content a:hover { text-decoration: underline; }
      .preview-content strong { color: #f0f6fc; }
      .preview-content em { color: #d2a8ff; }
      .preview-content hr { border: none; border-top: 1px solid #21262d; margin: 1rem 0; }
      .preview-content table { border-collapse: collapse; margin: 0.5rem 0; width: 100%; }
      .preview-content th, .preview-content td { border: 1px solid #30363d; padding: 0.4rem 0.8rem; text-align: left; }
      .preview-content th { background: #161b22; }
    </style>
  </head>
  <body>
    <header>
      <h1>Markdown Editor</h1>
      <span class="badge">WASM + KaTeX</span>
      <nav style="margin-left: auto; display: flex; gap: 0.75rem; font-size: 0.85rem;">
        <a href="/" style="color: #8b949e; text-decoration: none;">Local</a>
        <a href="/collab/demo" style="color: #58a6ff; text-decoration: none;">Collab</a>
      </nav>
    </header>
    <%= @inner_content %>
    <script defer phx-track-static src={"/assets/app.js"}></script>
  </body>
</html>
