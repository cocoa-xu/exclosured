<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title>Offload Computation Demo - Exclosured</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 960px;
        margin: 0 auto;
        padding: 2rem;
        background: #1a1a2e;
        color: #eee;
      }
      h1 { margin-bottom: 0.5rem; color: #e94560; }
      p.desc { color: #aaa; margin-bottom: 1.5rem; line-height: 1.5; }
      textarea {
        width: 100%;
        height: 200px;
        padding: 0.75rem;
        border-radius: 8px;
        border: 1px solid #333;
        background: #16213e;
        color: #eee;
        font-family: monospace;
        font-size: 0.85rem;
        resize: vertical;
        line-height: 1.4;
      }
      .btn-row {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
      }
      button {
        padding: 0.75rem 2rem;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
      }
      button:hover { opacity: 0.85; }
      button:disabled { opacity: 0.4; cursor: not-allowed; }
      .btn-server { background: #e94560; color: white; }
      .btn-wasm { background: #7bed9f; color: #1a1a2e; }
      .results {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-top: 1.5rem;
      }
      .panel {
        padding: 1rem;
        border-radius: 8px;
        background: #16213e;
        border: 1px solid #333;
      }
      .panel h3 {
        margin-bottom: 0.5rem;
        font-size: 1rem;
      }
      .panel-server h3 { color: #e94560; }
      .panel-wasm h3 { color: #7bed9f; }
      .panel .timing {
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
        padding: 0.4rem 0.6rem;
        border-radius: 4px;
        display: inline-block;
      }
      .panel-server .timing { background: rgba(233, 69, 96, 0.15); color: #e94560; }
      .panel-wasm .timing { background: rgba(123, 237, 159, 0.15); color: #7bed9f; }
      .panel pre {
        white-space: pre-wrap;
        word-break: break-word;
        color: #ccc;
        font-size: 0.85rem;
        line-height: 1.5;
        max-height: 300px;
        overflow-y: auto;
      }
      .status { color: #aaa; font-size: 0.9rem; margin-top: 0.5rem; }
      @media (max-width: 640px) {
        .results { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <%= @inner_content %>
    <script defer phx-track-static src={"/assets/app.js"}></script>
  </body>
</html>
