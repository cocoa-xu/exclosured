<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title>Streaming Results Demo - Exclosured</title>
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem;
        background: #0a0a1a;
        color: #eee;
      }

      h1 {
        color: #feca57;
        margin-bottom: 0.25rem;
        font-size: 1.8rem;
      }

      .subtitle {
        color: #888;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
        line-height: 1.5;
      }

      .input-section {
        background: #111128;
        border: 1px solid #222;
        border-radius: 10px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
      }

      .input-row {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
        flex-wrap: wrap;
      }

      .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .input-group label {
        color: #999;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .input-group input[type="number"] {
        width: 160px;
        padding: 0.6rem 0.8rem;
        border-radius: 6px;
        border: 1px solid #333;
        background: #0a0a1a;
        color: #eee;
        font-size: 1rem;
        font-family: monospace;
      }

      .input-group input[type="number"]:focus {
        outline: none;
        border-color: #feca57;
      }

      button.find-btn {
        padding: 0.6rem 1.5rem;
        border: none;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        background: #feca57;
        color: #0a0a1a;
        transition: opacity 0.2s;
      }

      button.find-btn:hover { opacity: 0.85; }
      button.find-btn:disabled { opacity: 0.35; cursor: not-allowed; }

      .progress-section {
        background: #111128;
        border: 1px solid #222;
        border-radius: 10px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
      }

      .progress-bar-outer {
        width: 100%;
        height: 8px;
        background: #1a1a3a;
        border-radius: 4px;
        overflow: hidden;
        margin-bottom: 0.75rem;
      }

      .progress-bar-inner {
        height: 100%;
        background: #feca57;
        border-radius: 4px;
        transition: width 0.15s ease;
      }

      .stats-row {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
        font-size: 0.9rem;
      }

      .stat {
        color: #aaa;
      }

      .stat .value {
        color: #feca57;
        font-weight: 600;
        font-family: monospace;
      }

      .results-section {
        background: #111128;
        border: 1px solid #222;
        border-radius: 10px;
        padding: 1.25rem;
        margin-bottom: 1.25rem;
      }

      .results-section h2 {
        color: #feca57;
        font-size: 1rem;
        margin-bottom: 0.75rem;
      }

      .primes-container {
        max-height: 300px;
        overflow-y: auto;
        background: #0a0a1a;
        border: 1px solid #1a1a3a;
        border-radius: 8px;
        padding: 0.75rem;
        font-family: monospace;
        font-size: 0.82rem;
        line-height: 1.6;
        color: #ccc;
      }

      .primes-container::-webkit-scrollbar {
        width: 6px;
      }

      .primes-container::-webkit-scrollbar-track {
        background: #0a0a1a;
      }

      .primes-container::-webkit-scrollbar-thumb {
        background: #333;
        border-radius: 3px;
      }

      .primes-empty {
        color: #555;
        font-style: italic;
        text-align: center;
        padding: 2rem 0;
      }

      .note {
        background: #0d0d24;
        border: 1px solid #1a1a3a;
        border-radius: 10px;
        padding: 1.25rem;
        margin-top: 1.25rem;
      }

      .note p {
        color: #888;
        font-size: 0.85rem;
        line-height: 1.6;
      }

      .note code {
        background: #1a1a3a;
        color: #feca57;
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.82rem;
      }

      .status {
        color: #555;
        font-size: 0.85rem;
        margin-top: 0.5rem;
        text-align: center;
      }

      .status.ready {
        color: #4ade80;
      }

      @media (max-width: 640px) {
        .input-row { flex-direction: column; }
        .input-group input[type="number"] { width: 100%; }
      }
    </style>
  </head>
  <body>
    <%= @inner_content %>
    <script defer phx-track-static src={"/assets/app.js"}></script>
  </body>
</html>
